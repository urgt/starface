# === Postgres ===
POSTGRES_USER=starface
POSTGRES_PASSWORD=starface
POSTGRES_DB=starface
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://starface:starface@localhost:5432/starface

# === Redis ===
REDIS_URL=redis://localhost:6379

# === ML service ===
ML_SERVICE_URL=http://localhost:8000
# When web runs inside docker-compose, ML_SERVICE_URL=http://ml:8000

# === Web ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Basic auth for /admin
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# === Storage ===
# Absolute path on the host for uploaded files (celebrity + user photos).
# When running via docker-compose, /data is mounted into web + ml containers.
DATA_DIR=./data

# === Match tuning ===
# Cosine similarity cutoff below which match is considered "no match".
MATCH_MIN_COSINE=0.2
# Public-facing percentage floor/ceiling for UX (pleasant "always ≥60%, never 100%")
DISPLAY_MIN_PCT=60
DISPLAY_MAX_PCT=97

# === Retention ===
USER_PHOTO_TTL_HOURS=24
