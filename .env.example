# =============================================================================
# PROD (Cloudflare) — bindings и vars лежат в apps/web/wrangler.toml.
# Секреты добавляются через `wrangler secret put <NAME>`:
#   ADMIN_USER, ADMIN_PASSWORD, BRAND_ANALYTICS_TOKEN_SALT, CRON_SHARED_SECRET.
# =============================================================================

# =============================================================================
# LOCAL DEV / SEED SCRIPTS (на машине оператора)
# =============================================================================

# Basic Auth для админ-API прода, который дёргает локальный seed-скрипт.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# Целевой прод для scripts/seed/*.ts
PROD_URL=https://starface.pages.dev

# === Локальная LLM для генерации описаний (scripts/seed/descriptions.ts) ===
# Ollama default:
#   LM_BASE_URL=http://127.0.0.1:11434/v1
#   LM_MODEL=llama3.1:8b
# LM Studio default:
LM_BASE_URL=http://127.0.0.1:1234/v1
LM_API_KEY=lmstudio
LM_MODEL=google/gemma-4-e4b

# === Match tuning (должны совпадать с vars в wrangler.toml) ===
MATCH_MIN_COSINE=0.2
DISPLAY_MIN_PCT=60
DISPLAY_MAX_PCT=97
USER_PHOTO_TTL_HOURS=24

# =============================================================================
# LEGACY (docker-compose локальная разработка с apps/ml, Postgres, Redis)
# Прод на Cloudflare эти значения игнорирует.
# =============================================================================
POSTGRES_USER=starface
POSTGRES_PASSWORD=starface
POSTGRES_DB=starface
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://starface:starface@localhost:5432/starface
REDIS_URL=redis://localhost:6379
ML_SERVICE_URL=http://localhost:8000
DATA_DIR=./data
