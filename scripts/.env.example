# Target prod (or local preview) that exposes /api/admin/*
PROD_URL=https://starface.pages.dev
ADMIN_USER=admin
ADMIN_PASSWORD=

# YuNet ONNX for local enrollment (scripts/seed/py/). Same blob the Modal
# container downloads at build time. Place under scripts/models/yunet.onnx.
YUNET_MODEL_PATH=./models/yunet.onnx

# Local LLM (Ollama or LM Studio). OpenAI-compatible endpoint.
LM_BASE_URL=http://127.0.0.1:1234/v1
LM_API_KEY=lmstudio
LM_MODEL=gemma-4-26b-a4b-it

# Wikidata output / download cache
SEED_OUT_DIR=./seeds/wikidata
SEED_USER_AGENT=StarFaceUZ-seed/0.1 (https://github.com/; contact@starface.uz)
